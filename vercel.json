{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    },
    {
      "src": "api/**/*.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/health",
      "dest": "/api/health.py"
    },
    {
      "src": "/api/chat",
      "dest": "/api/chat.py"
    },
    {
      "src": "/api/conversations",
      "dest": "/api/conversations.py"
    },
    {
      "src": "/api/conversations/([^/]+)/messages",
      "dest": "/api/messages.py"
    },
    {
      "src": "/api/upload/analyze",
      "dest": "/api/upload.py"
    },
    {
      "src": "/api/documents",
      "dest": "/api/documents.py"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
}
